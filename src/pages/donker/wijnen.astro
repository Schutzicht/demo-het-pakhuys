---
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import { menus, site } from "../../data/site";

const priceLabel = (glass: string | null, bottle: string | null) =>
  glass && bottle ? `€${glass} / €${bottle}` : glass ? `€${glass} per glas` : bottle ? `€${bottle} per fles` : "";

const wineList = [
  {
    cat: "Mousserend",
    items: [
      { name: "Crémant de Loire, Brut", region: "Loire, Frankrijk", glass: "9", bottle: "46" },
      { name: "Champagne Brut Tradition", region: "Champagne, Frankrijk", glass: "14", bottle: "78" },
    ],
  },
  {
    cat: "Wit",
    items: [
      { name: "Muscadet Sèvre et Maine sur Lie", region: "Loire, Frankrijk", glass: "8", bottle: "38" },
      { name: "Chablis", region: "Bourgogne, Frankrijk", glass: "11", bottle: "54" },
      { name: "Sancerre", region: "Loire, Frankrijk", glass: "12", bottle: "58" },
      { name: "Riesling Trocken", region: "Pfalz, Duitsland", glass: "9", bottle: "44" },
    ],
  },
  {
    cat: "Rood",
    items: [
      { name: "Côtes du Rhône", region: "Rhône, Frankrijk", glass: "8", bottle: "38" },
      { name: "Bourgogne Pinot Noir", region: "Bourgogne, Frankrijk", glass: "12", bottle: "60" },
      { name: "Châteauneuf-du-Pape", region: "Rhône, Frankrijk", glass: null, bottle: "82" },
    ],
  },
  {
    cat: "Zoet & dessert",
    items: [
      { name: "Sauternes", region: "Bordeaux, Frankrijk", glass: "9", bottle: "62" },
      { name: "Port, Tawny 10 jaar", region: "Douro, Portugal", glass: "8", bottle: null },
    ],
  },
];
---

<Base title="Wijnen | Het Packhuys" description="Het wijnarrangement en de wijnkaart van Het Packhuys: per gang afgestemd, met klassiekers uit Frankrijk en daarbuiten.">
  <section class="page-hero">
    <div class="page-hero__media" aria-hidden="true"><img src="/photos/wijn-inschenken.jpg" alt="" /></div>
    <div class="page-hero__inner container">
      <p class="crumbs"><a href="/donker" class="link-underline">Home</a> &nbsp;/&nbsp; Wijnen</p>
      <h1>Wijnen</h1>
      <p>Een kelder die het menu volgt. Per gang schenken we een glas dat het gerecht een hand geeft, of u stelt zelf samen uit de kaart.</p>
    </div>
  </section>

  <!-- Wijnarrangement -->
  <section class="section">
    <div class="container split">
      <div data-reveal>
        <p class="eyebrow">Het wijnarrangement</p>
        <h2 class="sec-title mt-3">Per gang afgestemd</h2>
        <p class="mt-4 text-[color:var(--color-ink-70)] leading-relaxed">
          Bij elk tasting menu kunt u kiezen voor een bijpassend wijnarrangement. Onze gastvrouw selecteert per gang een glas, van een frisse opener tot een wijn met body bij het hoofdgerecht. Niet zomaar een wijn erbij, maar een keuze die het gerecht laat oplichten.
        </p>
        <ul class="mt-6 grid gap-2.5 max-w-[24rem]">
          {menus.map((m) => (
            <li class="flex items-center justify-between gap-4 py-2 border-b border-[color:var(--color-line)]">
              <span class="flex items-center gap-2.5"><Icon name="wine" size={16} class="text-[color:var(--accent-dark)]" /> {m.courses} glazen, bij {m.courses} gangen</span>
              <span class="font-display text-xl">&euro;{m.wine}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="frame frame--tall frame-hover" data-reveal style="--reveal-delay: 100ms">
        <img src="/photos/bar-drinks.jpg" alt="Dranken aan de bar van Het Packhuys" />
      </div>
    </div>
  </section>

  <!-- Wijnkaart -->
  <section class="section surface-sand">
    <div class="container-narrow">
      <div class="sec-head sec-head--center text-center mb-10" data-reveal>
        <p class="eyebrow eyebrow--center justify-center">Per glas of per fles</p>
        <h2 class="sec-title mt-3">Een greep uit de kaart</h2>
      </div>

      <div class="grid gap-10">
        {wineList.map((group, gi) => (
          <div data-reveal style={`--reveal-delay: ${gi * 60}ms`}>
            <div class="flex items-baseline justify-between border-b border-[color:var(--color-line)] pb-2 mb-2">
              <h3 class="font-display text-2xl">{group.cat}</h3>
              <span class="text-[0.68rem] uppercase tracking-[0.16em] text-[color:var(--color-ink-55)]">glas / fles</span>
            </div>
            {group.items.map((w) => (
              <div class="flex items-baseline justify-between gap-4 py-2.5 border-b border-[color:var(--color-line)] last:border-0">
                <div>
                  <div class="font-display text-lg leading-tight">{w.name}</div>
                  <div class="text-[0.82rem] text-[color:var(--color-ink-55)]">{w.region}</div>
                </div>
                <div class="font-display text-lg whitespace-nowrap text-[color:var(--accent-dark)]">
                  {priceLabel(w.glass, w.bottle)}
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
      <p class="text-center text-[0.78rem] text-[color:var(--color-ink-55)] mt-10">Illustratieve selectie voor deze demo. De actuele kaart ligt op tafel.</p>
    </div>
  </section>

  <!-- Alcoholvrij -->
  <section class="section-sm">
    <div class="container">
      <div class="surface-ink rounded-[12px] p-8 md:p-12 grid gap-8 md:grid-cols-[1.3fr_1fr] items-center" data-reveal>
        <div>
          <p class="eyebrow eyebrow--light">Liever zonder alcohol</p>
          <h2 class="font-display mt-3" style="font-size: clamp(1.8rem,3.6vw,2.6rem); color: var(--color-cream);">Een alcoholvrij arrangement</h2>
          <p class="mt-4 text-[rgba(244,238,226,0.82)] leading-relaxed">
            Ook zonder alcohol verzorgen we een arrangement per gang: huisgemaakte kombucha, verjus, infusies van kruiden en seizoensfruit. Even doordacht als de wijnen, geef het door bij uw reservering.
          </p>
        </div>
        <div class="flex md:justify-end">
          <button type="button" class="btn btn-brass" data-reserve-open>Reserveren<Icon name="arrow" size={14} stroke={2} /></button>
        </div>
      </div>
    </div>
  </section>
</Base>
