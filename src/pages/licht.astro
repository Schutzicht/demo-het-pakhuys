---
import Base from "../layouts/BaseLicht.astro";
import Icon from "../components/Icon.astro";
import { site, dishes, reviews } from "../data/site";

const email = "info@hetpackhuys.nl";

// Configurator-data (JS-logica blijft gelijk aan de donkere demo)
const menus = [
  { courses: 4, price: 58, wine: 36 },
  { courses: 5, price: 67, wine: 45 },
  { courses: 6, price: 76, wine: 54 },
  { courses: 7, price: 83, wine: 63 },
];
const savory = dishes.slice(1, 7).map((d) => ({ name: d.name, vega: !!d.vega }));
const dessert = { name: dishes[7].name };

// Menukaart: gerechten + ZEE/LAND/VEGA/ZOET-tags
const tagFor = (d: any) =>
  d.name.includes("Aardbei") ? "zoet"
  : d.tags.includes("Vis") || d.tags.includes("Uit het homarium") ? "zee"
  : d.vega ? "vega" : "land";
const tagLabel: Record<string, string> = { zee: "Zee", land: "Land", vega: "Vega", zoet: "Zoet" };
const menuItems = dishes.slice(1);

const hoursRows = [
  { day: "Maandag", v: "18:00 tot 21:00" },
  { day: "Dinsdag", v: "18:00 tot 21:00" },
  { day: "Woensdag", v: "Gesloten", closed: true },
  { day: "Donderdag", v: "18:00 tot 21:00" },
  { day: "Vrijdag", v: "18:00 tot 21:00" },
  { day: "Zaterdag", v: "18:00 tot 21:00" },
  { day: "Zondag", v: "Gesloten", closed: true },
];
const jsDay = (i: number) => (i + 1) % 7;
const igPhotos = ["gerecht-zeebaars", "interieur-avond", "wijn-inschenken", "haven-masten", "chef-plating", "gasten-diner"];
---

<Base loader={true}>
  <!-- 1. Hero -->
  <section class="hero on-photo">
    <div class="hero__bg" aria-hidden="true">
      <video autoplay muted loop playsinline poster="/photos/pand-buiten.jpg">
        <source src="/video/hero.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="hero__veil" aria-hidden="true"></div>
    <div class="hero__inner">
      <div class="container">
        <p class="eyebrow eyebrow--light" data-hero-fade>Aan de haven &middot; Middelburg</p>
        <h1 class="hero__title mt-5" data-hero-name>Het <span class="accent">Packhuys</span></h1>
        <p class="hero__sub" data-hero-fade>
          Een verfijnd seizoensmenu in een eeuwenoud pakhuis aan de jachthaven. Oesters en kreeft uit ons eigen homarium, alles van eigen hand.
        </p>
        <div class="hero__actions" data-hero-fade>
          <button type="button" class="btn btn-light" data-reserve-open>Reserveer een tafel <Icon name="arrow" size={14} stroke={1.8} /></button>
          <a href="#menu" class="btn btn-outline">Bekijk de kaart</a>
        </div>
      </div>
    </div>
    <span class="scroll-cue" aria-hidden="true">Scroll<span class="scroll-cue__rail"></span></span>
  </section>

  <!-- 2. Seizoens-lint -->
  <div class="ribbon">
    <div class="ribbon__in">
      <span>Ons <b>zomermenu</b> staat klaar, geserveerd t/m eind augustus</span>
      <a href="#menu">Bekijk de kaart</a>
    </div>
  </div>

  <!-- 3. Het pakhuis / Ons verhaal -->
  <section class="section" id="verhaal">
    <div class="container split split--wide-text">
      <div>
        <p class="eyebrow" data-anim="up">Het pakhuis</p>
        <h2 class="statement mt-5" data-anim="up">Dineren waar ooit de <span class="accent">handel</span> lag opgeslagen.</h2>
        <p class="mt-6 text-[color:var(--color-ink-soft)] leading-relaxed max-w-[52ch]" data-anim="up">
          Achter de dikke muren aan de Kinderdijk schuift u aan onder eeuwenoud hout, met uitzicht over de boten van de jachthaven. Onze keuken werkt met wat het seizoen en de Zeeuwse delta op dat moment te bieden hebben, geen onnodige opsmuk, wel gerechten die kloppen.
        </p>
        <a href="#menu" class="link-line mt-7" data-anim="up">Naar de menukaart <Icon name="arrow" size={15} stroke={1.8} /></a>
      </div>
      <div class="frame frame--tall frame-hover" data-anim="up">
        <img src="/photos/interieur-tafels.jpg" alt="Gedekte tafels onder de balken van Het Packhuys" loading="lazy" />
        <span class="tag-pill">Sinds de Zeeuwse handelstijd &middot; Kinderdijk 84</span>
      </div>
    </div>
  </section>

  <!-- 4. Homarium (cinematic) -->
  <section class="cinema on-photo">
    <div class="cinema__bg" aria-hidden="true"><img src="/photos/generated/homarium.jpg" alt="" data-parallax="8" /></div>
    <div class="cinema__veil" aria-hidden="true"></div>
    <div class="cinema__body">
      <div class="container">
        <img src="/brand/homarium-crest.png" alt="Homarium" class="cinema__crest" data-anim="up" />
        <p class="eyebrow eyebrow--light" data-anim="up">Onze signatuur</p>
        <h2 class="cinema__title mt-4" data-anim="up">Recht uit het <span class="accent">homarium</span></h2>
        <p class="cinema__text" data-anim="up">
          Oesters, langoustines en kreeft leven in een aquarium met gekoeld Oosterscheldewater, tot het moment dat ze op uw bord komen. De kortste route die er bestaat tussen de zee en de tafel.
        </p>
        <div class="facts" data-anim="up">
          <div><div class="fact__n">Drie soorten</div><div class="fact__l">Oester, langoustine en kreeft</div></div>
          <div><div class="fact__n">Levend</div><div class="fact__l">In gekoeld Oosterscheldewater</div></div>
          <div><div class="fact__n">Van eigen hand</div><div class="fact__l">Alles vers uit onze keuken</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Menukaart -->
  <section class="section" id="menu">
    <div class="container">
      <div class="max-w-[60ch]" data-stagger>
        <p class="eyebrow" data-anim="up">De kaart</p>
        <h2 class="sec-title mt-5" data-anim="up">Een menu dat <span class="accent">meebeweegt</span> met het seizoen</h2>
        <p class="lede mt-4" data-anim="up">
          Geen vaste kaart, maar losse gerechten die met de oogst en de vangst wisselen. U kiest het aantal gangen, de keuken verrast u.
        </p>
      </div>
      <div class="menu-grid mt-10" data-anim="up">
        {menuItems.map((d) => {
          const t = tagFor(d);
          return (
            <div class="dish">
              <div class="dish__head">
                <span class="dish__name">{d.name}</span>
                <span class="dish__tags"><span class={`tag tag--${t}`}>{tagLabel[t]}</span></span>
              </div>
              <p class="dish__desc">{d.desc}</p>
            </div>
          );
        })}
        <div class="dish dish--note">
          <div class="dish__head"><span class="dish__name">…en wat de dag verder brengt</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Configurator -->
  <section class="section surface-bone2">
    <div class="container">
      <div class="max-w-[58ch] mb-10" data-stagger>
        <p class="eyebrow" data-anim="up">Stel uw avond samen</p>
        <h2 class="sec-title mt-5" data-anim="up"><span class="accent">Hoever</span> gaat u mee?</h2>
        <p class="lede mt-4" data-anim="up">Kies het aantal gangen en de begeleiding, dan ziet u meteen hoe uw avond eruitziet en wat het kost.</p>
      </div>
      <div class="config" data-config data-anim="up">
        <div class="config__form">
          <div class="config__field">
            <span class="config__qlabel">Aantal gangen</span>
            <div class="seg" role="group" aria-label="Aantal gangen">
              {menus.map((m) => (
                <button type="button" class="seg__btn" data-cfg="gangen" data-val={m.courses} aria-pressed={m.courses === 5 ? "true" : "false"}>{m.courses} gangen</button>
              ))}
            </div>
          </div>
          <div class="config__field">
            <span class="config__qlabel">Wijnbegeleiding</span>
            <div class="seg" role="group" aria-label="Wijnbegeleiding">
              <button type="button" class="seg__btn" data-cfg="wijn" data-val="geen" aria-pressed="false">Geen</button>
              <button type="button" class="seg__btn" data-cfg="wijn" data-val="wijn" aria-pressed="true">Wijnarrangement</button>
              <button type="button" class="seg__btn" data-cfg="wijn" data-val="vrij" aria-pressed="false">Alcoholvrij</button>
            </div>
          </div>
          <div class="config__field">
            <span class="config__qlabel">Voorkeur</span>
            <div class="seg" role="group" aria-label="Voorkeur">
              <button type="button" class="seg__btn" data-cfg="dieet" data-val="standaard" aria-pressed="true">Verrassen</button>
              <button type="button" class="seg__btn" data-cfg="dieet" data-val="vega" aria-pressed="false">Vegetarisch</button>
            </div>
          </div>
          <p class="text-[0.8rem] text-[color:var(--color-muted)] mt-6 leading-relaxed">
            Een indicatie op basis van onze menu's. De keuken stelt de definitieve gangen samen rond het seizoen.
          </p>
        </div>
        <div class="config__panel">
          <span class="config__qlabel">Uw avond</span>
          <div class="config__price-row">
            <span class="config__price" data-cfg-price>&euro;112</span>
            <span class="config__price-sub">per persoon</span>
          </div>
          <div class="config__break" data-cfg-break></div>
          <div class="config__menu" data-cfg-menu></div>
          <button type="button" class="btn btn-light config__cta" data-reserve-open>Reserveer deze avond <Icon name="arrow" size={14} stroke={1.8} /></button>
        </div>
      </div>
    </div>

    <script is:inline define:vars={{ menus, savory, dessert }}>
      (function () {
        const state = { gangen: 5, wijn: "wijn", dieet: "standaard" };
        const euro = (n) => "€" + n;
        const compute = () => {
          const menu = menus.find((m) => m.courses === state.gangen) || menus[1];
          const wijn = state.wijn === "geen" ? 0 : state.wijn === "wijn" ? menu.wine : Math.round(menu.wine * 0.6);
          return { menuPrice: menu.price, wijn, total: menu.price + wijn };
        };
        const render = () => {
          const { menuPrice, wijn, total } = compute();
          const priceEl = document.querySelector("[data-cfg-price]");
          if (priceEl) priceEl.textContent = euro(total);
          const breakEl = document.querySelector("[data-cfg-break]");
          if (breakEl) {
            let h = `<span>Menu, ${state.gangen} gangen <b>${euro(menuPrice)}</b></span>`;
            if (state.wijn === "wijn") h += `<span>Wijnarrangement <b>${euro(wijn)}</b></span>`;
            else if (state.wijn === "vrij") h += `<span>Alcoholvrij arrangement <b>${euro(wijn)}</b></span>`;
            breakEl.innerHTML = h;
          }
          const menuEl = document.querySelector("[data-cfg-menu]");
          if (menuEl) {
            const courses = savory.slice(0, state.gangen - 1).concat([dessert]);
            menuEl.innerHTML = courses
              .map((c, i) => {
                const note = state.dieet === "vega" && !c.vega ? '<span class="config__course-note">vegetarische variant</span>' : "";
                return `<div class="config__course"><span class="config__course-n">${String(i + 1).padStart(2, "0")}</span><span class="config__course-name">${c.name}${note}</span></div>`;
              })
              .join("");
          }
          document.querySelectorAll("[data-cfg]").forEach((btn) => {
            const grp = btn.getAttribute("data-cfg");
            btn.setAttribute("aria-pressed", String(state[grp]) === btn.getAttribute("data-val") ? "true" : "false");
          });
        };
        const setup = () => {
          const root = document.querySelector("[data-config]");
          if (!root) return;
          root.querySelectorAll("[data-cfg]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const grp = btn.getAttribute("data-cfg");
              let val = btn.getAttribute("data-val");
              if (grp === "gangen") val = parseInt(val, 10);
              state[grp] = val;
              render();
            });
          });
          render();
        };
        if (!window.__cfgBound) { window.__cfgBound = true; document.addEventListener("astro:page-load", setup); }
      })();
    </script>
  </section>

  <!-- 7. Wijnen -->
  <section class="section" id="wijnen">
    <div class="container split split--wide-img">
      <div class="frame frame--tall frame-hover" data-anim="up">
        <img src="/photos/wijn-tafel.jpg" alt="Wijn wordt ingeschonken aan tafel" loading="lazy" />
        <span class="tag-pill">Wisselt mee per seizoen</span>
      </div>
      <div data-anim="up">
        <p class="eyebrow">De wijnen</p>
        <h2 class="sec-title mt-5">Per gang <span class="accent">afgestemd</span></h2>
        <p class="mt-5 text-[color:var(--color-ink-soft)] leading-relaxed max-w-[50ch]">
          Bij elk tasting menu kunt u kiezen voor een bijpassend wijnarrangement. Onze gastvrouw selecteert per gang een glas dat het gerecht een hand geeft, van een frisse opener tot een wijn met body bij het hoofdgerecht.
        </p>
        <ul class="mt-6 max-w-[24rem]">
          <li class="flex items-center justify-between gap-4 py-2.5 border-b border-[color:var(--color-line-soft)]"><span class="flex items-center gap-2.5"><Icon name="wine" size={16} class="text-[color:var(--color-accent-deep)]" /> 4 glazen</span><span class="font-display text-xl">&euro;36</span></li>
          <li class="flex items-center justify-between gap-4 py-2.5 border-b border-[color:var(--color-line-soft)]"><span class="flex items-center gap-2.5"><Icon name="wine" size={16} class="text-[color:var(--color-accent-deep)]" /> 5 glazen</span><span class="font-display text-xl">&euro;45</span></li>
          <li class="flex items-center justify-between gap-4 py-2.5 border-b border-[color:var(--color-line-soft)]"><span class="flex items-center gap-2.5"><Icon name="wine" size={16} class="text-[color:var(--color-accent-deep)]" /> 6 glazen</span><span class="font-display text-xl">&euro;54</span></li>
          <li class="flex items-center justify-between gap-4 py-2.5"><span class="flex items-center gap-2.5"><Icon name="wine" size={16} class="text-[color:var(--color-accent-deep)]" /> 7 glazen</span><span class="font-display text-xl">&euro;63</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 8. Galerij -->
  <section class="section-sm">
    <div class="container">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-7" data-anim="up">
        <div><p class="eyebrow">In beeld</p><h2 class="sec-title mt-4">Het pakhuis &amp; de haven</h2></div>
        <a href={site.social.instagram} target="_blank" rel="noopener" class="link-line">Volg ons <Icon name="arrowUpRight" size={15} /></a>
      </div>
      <div class="gallery" data-anim="up">
        <a href="#menu" class="g-a"><img src="/photos/keuken-plating.jpg" alt="Gerecht wordt opgemaakt in de keuken" loading="lazy" /></a>
        <a href="#gezelschappen" class="g-b"><img src="/photos/gasten-haven.jpg" alt="Gasten aan de haven" loading="lazy" /></a>
        <a href="#menu" class="g-c"><img src="/photos/gerecht-handen.jpg" alt="Afwerken van een gerecht" loading="lazy" /></a>
        <a href="#verhaal" class="g-d"><img src="/photos/haven-stad.jpg" alt="Zicht op Middelburg vanaf de haven" loading="lazy" /></a>
        <a href="#verhaal" class="g-e"><img src="/photos/interieur-tafels.jpg" alt="Gedekte tafels onder de balken" loading="lazy" /></a>
      </div>
    </div>
  </section>

  <!-- 9. Reviews -->
  <section class="section">
    <div class="container">
      <div class="mb-9 text-center max-w-[52ch] mx-auto" data-anim="up">
        <p class="eyebrow eyebrow--center justify-center">Gasten aan het woord</p>
        <h2 class="sec-title mt-4">Een avond om <span class="accent">bij te blijven</span></h2>
      </div>
      <div class="reviews" data-stagger>
        {reviews.map((r) => (
          <div class="review" data-anim="up">
            <div class="review__stars">{Array.from({ length: 5 }).map(() => <Icon name="star" size={15} stroke={0} class="fill-current" />)}</div>
            <p class="review__q">&ldquo;{r.q}&rdquo;</p>
            <div class="review__foot">
              <div><div class="review__name">{r.name}</div><div class="review__meta">{r.place}</div></div>
              <div class="review__src">{r.src}</div>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-[0.78rem] text-[color:var(--color-muted)] mt-7">Illustratieve gastreacties voor deze demo.</p>
    </div>
  </section>

  <!-- 10. Gezelschappen -->
  <section class="section-sm" id="gezelschappen">
    <div class="container">
      <div class="max-w-[58ch] mb-8" data-anim="up">
        <p class="eyebrow">Gezelschappen</p>
        <h2 class="sec-title mt-4">Samen aan tafel onder de <span class="accent">balken</span></h2>
        <p class="lede mt-4">Tot 50 gasten binnen en 35 op het terras. Een familiefeest, zakelijk diner of bruiloft, wij stellen een maatwerkmenu samen en denken graag mee, ook buiten de reguliere tijden.</p>
      </div>
      <div class="occ-grid" data-stagger>
        <div class="occ" data-anim="up">
          <img src="/photos/gasten-haven.jpg" alt="Gasten aan de haven bij Het Packhuys" loading="lazy" />
          <div class="occ__body">
            <div class="font-display text-2xl">Familie &amp; feest</div>
            <p class="text-sm mt-1.5 text-[rgba(255,255,255,.82)] max-w-[34ch]">Een verjaardag, jubileum of bruiloft, in een zaal die vanzelf het gesprek op gang brengt.</p>
            <button type="button" class="btn btn-outline mt-5" data-reserve-open>Mogelijkheden</button>
          </div>
        </div>
        <div class="occ" data-anim="up">
          <img src="/photos/haven-stad.jpg" alt="Zicht op de haven van Middelburg" loading="lazy" />
          <div class="occ__body">
            <div class="font-display text-2xl">Zakelijk diner</div>
            <p class="text-sm mt-1.5 text-[rgba(255,255,255,.82)] max-w-[34ch]">Relaties verrassen of het team bedanken, met een vast menu en alle aandacht voor het bord.</p>
            <a href="#contact" class="btn btn-outline mt-5">Plan een diner</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. Reserveren & contact -->
  <section class="section surface-bone2" id="contact">
    <div class="container grid gap-10 lg:grid-cols-2 items-start">
      <div data-anim="up">
        <p class="eyebrow">Reserveren &amp; contact</p>
        <h2 class="sec-title mt-4">Aan de Kinderdijk</h2>
        <div class="mt-7">
          <a href={site.maps} target="_blank" rel="noopener" class="info-row">
            <span class="info-row__ic"><Icon name="pin" size={18} /></span>
            <span class="flex-1"><span class="info-row__t block">Kinderdijk 84</span><span class="info-row__s">4331 HH Middelburg</span></span>
            <Icon name="arrowUpRight" size={16} class="text-[color:var(--color-muted)] self-center" />
          </a>
          <a href={site.phoneHref} class="info-row">
            <span class="info-row__ic"><Icon name="phone" size={18} /></span>
            <span class="flex-1"><span class="info-row__t block">Bel ons</span><span class="info-row__s">{site.phone}</span></span>
          </a>
          <a href={`mailto:${email}`} class="info-row">
            <span class="info-row__ic"><Icon name="mail" size={18} /></span>
            <span class="flex-1"><span class="info-row__t block">Mail ons</span><span class="info-row__s">{email}</span></span>
          </a>
          <div class="info-row">
            <span class="info-row__ic"><Icon name="clock" size={18} /></span>
            <span class="flex-1">
              <span class="info-row__t block">Openingstijden</span>
              <ul class="hours mt-2">
                {hoursRows.map((h, i) => (
                  <li data-day={jsDay(i)}><span class="day">{h.day}</span>{h.closed ? <span class="closed">Gesloten</span> : <span>{h.v}</span>}</li>
                ))}
              </ul>
              <div class="open-status mt-3" data-open-status><span class="open-status__dot"></span><span data-open-status-text>Openingstijden</span></div>
            </span>
          </div>
        </div>
      </div>

      <div data-anim="up" style="--reveal-delay: 100ms">
        <div class="booking-card">
          <p class="rc-eyebrow">Reserveren</p>
          <h3 class="font-display text-[1.8rem] mt-2 leading-tight">Een tafel aan de haven</h3>
          <p class="text-sm text-[color:var(--color-muted)] mt-2 leading-relaxed">Reserveer online via ons boekingssysteem, of neem persoonlijk contact op.</p>
          <div class="zenchef-ph mt-5">
            <div class="zenchef-ph__badge">ZenChef</div>
            <p class="text-sm text-[color:var(--color-muted)] mt-2 leading-relaxed">Hier komt de live ZenChef-boekingsmodule, gekoppeld aan jullie bestaande abonnement. De gast ziet meteen de beschikbaarheid en boekt direct.</p>
          </div>
          <div class="grid gap-2.5 mt-5">
            <a href={site.zenchef.reserve} target="_blank" rel="noopener" class="btn btn-solid w-full">Online reserveren <Icon name="arrowUpRight" size={14} stroke={1.8} /></a>
            <div class="grid grid-cols-2 gap-2.5">
              <a href={site.phoneHref} class="btn btn-outline">Bellen</a>
              <a href={`mailto:${email}`} class="btn btn-outline">Mailen</a>
            </div>
          </div>
        </div>
        <div class="map-frame mt-4" style="position:relative;width:100%;aspect-ratio:16/10;border-radius:var(--r);overflow:hidden;border:1px solid var(--color-line);box-shadow:var(--shadow);">
          <iframe src="https://www.google.com/maps?q=Kinderdijk+84,+4331+HH+Middelburg&output=embed" title="Kaart Het Packhuys" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;border:0;"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- 12. Instagram -->
  <section class="section-sm">
    <div class="container">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-7" data-anim="up">
        <div><p class="eyebrow">Instagram</p><h2 class="sec-title mt-4">@restauranthetpackhuys</h2></div>
        <a href={site.social.instagram} target="_blank" rel="noopener" class="btn btn-outline"><Icon name="instagram" size={16} /> Volgen</a>
      </div>
      <div class="ig" data-anim="up">
        {igPhotos.map((p) => (
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Bekijk op Instagram"><img src={`/photos/${p}.jpg`} alt="" loading="lazy" /></a>
        ))}
      </div>
      <p class="text-[0.8rem] text-[color:var(--color-muted)] mt-5 text-center">Live gekoppeld, toont automatisch jullie nieuwste posts.</p>
