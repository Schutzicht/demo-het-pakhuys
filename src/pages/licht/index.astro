---
import Base from "../../layouts/BaseLicht.astro";
import Icon from "../../components/Icon.astro";
import { dishes, reviews, stats } from "../../data/site";

// Configurator-data (JS-logica gelijk aan de donkere demo)
const menus = [
  { courses: 4, price: 58, wine: 36 },
  { courses: 5, price: 67, wine: 45 },
  { courses: 6, price: 76, wine: 54 },
  { courses: 7, price: 83, wine: 63 },
];
const savory = dishes.slice(1, 7).map((d) => ({ name: d.name, vega: !!d.vega }));
const dessert = { name: dishes[7].name };
const homeStats = [stats[0], stats[1], stats[3]];
---

<Base loader={true}>
  <!-- 1. Hero -->
  <section class="hero on-photo">
    <div class="hero__bg" aria-hidden="true">
      <video autoplay muted loop playsinline poster="/photos/pand-buiten.jpg">
        <source src="/video/hero.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="hero__veil" aria-hidden="true"></div>
    <div class="hero__inner">
      <div class="container">
        <p class="eyebrow eyebrow--light" data-hero-fade>Aan de haven &middot; Middelburg</p>
        <h1 class="hero__title mt-5" data-hero-name>Het <span class="accent">Packhuys</span></h1>
        <p class="hero__sub" data-hero-fade>
          Een verfijnd seizoensmenu in een eeuwenoud pakhuis aan de jachthaven. Oesters en kreeft uit ons eigen homarium, alles van eigen hand.
        </p>
        <div class="hero__actions" data-hero-fade>
          <button type="button" class="btn btn-light" data-reserve-open>Reserveer een tafel <Icon name="arrow" size={14} stroke={1.8} /></button>
          <a href="/licht/menukaart" class="btn btn-outline">Bekijk de kaart</a>
        </div>
      </div>
    </div>
    <span class="scroll-cue" aria-hidden="true">Scroll<span class="scroll-cue__rail"></span></span>
  </section>

  <!-- 2. Seizoens-lint -->
  <div class="ribbon">
    <div class="ribbon__in">
      <span>Ons <b>zomermenu</b> staat klaar, geserveerd t/m eind augustus</span>
      <a href="/licht/menukaart">Bekijk de kaart</a>
    </div>
  </div>

  <!-- 3. Het pakhuis / statement -->
  <section class="section">
    <div class="container split split--wide-text">
      <div>
        <p class="eyebrow" data-anim="up">Het pakhuis</p>
        <h2 class="statement mt-5" data-anim="up">Dineren waar ooit de <span class="accent">handel</span> lag opgeslagen, onder de balken van een echt pakhuis.</h2>
        <p class="mt-6 text-[color:var(--color-ink-soft)] leading-relaxed max-w-[52ch]" data-anim="up">
          Achter de dikke muren aan de Kinderdijk schuift u aan onder eeuwenoud hout, met uitzicht over de boten van de jachthaven. Onze keuken werkt met wat het seizoen en de Zeeuwse delta op dat moment te bieden hebben, geen onnodige opsmuk, wel gerechten die kloppen.
        </p>
        <a href="/licht/ons-verhaal" class="link-line mt-7" data-anim="up">Ons verhaal <Icon name="arrow" size={15} stroke={1.8} /></a>
      </div>
      <div class="frame frame--tall frame-hover" data-anim="up">
        <img src="/photos/interieur-tafels.jpg" alt="Gedekte tafels onder de balken van Het Packhuys" loading="lazy" />
        <span class="tag-pill">Sinds de Zeeuwse handelstijd &middot; Kinderdijk 84</span>
      </div>
    </div>
  </section>

  <!-- 4. Homarium (cinematic) -->
  <section class="cinema on-photo">
    <div class="cinema__bg" aria-hidden="true"><img src="/photos/generated/homarium.jpg" alt="" data-parallax="8" /></div>
    <div class="cinema__veil" aria-hidden="true"></div>
    <div class="cinema__body">
      <div class="container">
        <img src="/brand/homarium-crest.png" alt="Homarium" class="cinema__crest" data-anim="up" />
        <p class="eyebrow eyebrow--light" data-anim="up">Onze signatuur</p>
        <h2 class="cinema__title mt-4" data-anim="up">Recht uit het <span class="accent">homarium</span></h2>
        <p class="cinema__text" data-anim="up">
          Oesters, langoustines en kreeft leven in een aquarium met gekoeld Oosterscheldewater, tot het moment dat ze op uw bord komen. De kortste route die er bestaat tussen de zee en de tafel, en u proeft het verschil.
        </p>
        <div class="facts" data-anim="up">
          <div><div class="fact__n">Drie soorten</div><div class="fact__l">Oester, langoustine en kreeft</div></div>
          <div><div class="fact__n">Levend gehouden</div><div class="fact__l">In gekoeld Oosterscheldewater</div></div>
          <div><div class="fact__n">Van eigen hand</div><div class="fact__l">Alles vers uit onze keuken</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Configurator -->
  <section class="section surface-bone2">
    <div class="container">
      <div class="max-w-[58ch] mb-10" data-stagger>
        <p class="eyebrow" data-anim="up">Stel uw avond samen</p>
        <h2 class="sec-title mt-5"><span class="accent">Hoever</span> gaat u mee?</h2>
        <p class="lede mt-4" data-anim="up">Kies het aantal gangen en de begeleiding, dan ziet u meteen hoe uw avond eruitziet en wat het kost.</p>
      </div>
      <div class="config" data-config data-anim="up">
        <div class="config__form">
          <div class="config__field">
            <span class="config__qlabel">Aantal gangen</span>
            <div class="seg" role="group" aria-label="Aantal gangen">
              {menus.map((m) => (
                <button type="button" class="seg__btn" data-cfg="gangen" data-val={m.courses} aria-pressed={m.courses === 5 ? "true" : "false"}>{m.courses} gangen</button>
              ))}
            </div>
          </div>
          <div class="config__field">
            <span class="config__qlabel">Wijnbegeleiding</span>
            <div class="seg" role="group" aria-label="Wijnbegeleiding">
              <button type="button" class="seg__btn" data-cfg="wijn" data-val="geen" aria-pressed="false">Geen</button>
              <button type="button" class="seg__btn" data-cfg="wijn" data-val="wijn" aria-pressed="true">Wijnarrangement</button>
              <button type="button" class="seg__btn" data-cfg="wijn" data-val="vrij" aria-pressed="false">Alcoholvrij</button>
            </div>
          </div>
          <div class="config__field">
            <span class="config__qlabel">Voorkeur</span>
            <div class="seg" role="group" aria-label="Voorkeur">
              <button type="button" class="seg__btn" data-cfg="dieet" data-val="standaard" aria-pressed="true">Verrassen</button>
              <button type="button" class="seg__btn" data-cfg="dieet" data-val="vega" aria-pressed="false">Vegetarisch</button>
            </div>
          </div>
          <p class="text-[0.8rem] text-[color:var(--color-muted)] mt-6 leading-relaxed">
            Een indicatie op basis van onze menu's. De keuken stelt de definitieve gangen samen rond het seizoen.
          </p>
        </div>
        <div class="config__panel">
          <span class="config__qlabel">Uw avond</span>
          <div class="config__price-row">
            <span class="config__price" data-cfg-price>&euro;112</span>
            <span class="config__price-sub">per persoon</span>
          </div>
          <div class="config__break" data-cfg-break></div>
          <div class="config__menu" data-cfg-menu></div>
          <button type="button" class="btn btn-light config__cta" data-reserve-open>Reserveer deze avond <Icon name="arrow" size={14} stroke={1.8} /></button>
        </div>
      </div>
    </div>

    <script is:inline define:vars={{ menus, savory, dessert }}>
      (function () {
        const state = { gangen: 5, wijn: "wijn", dieet: "standaard" };
        const euro = (n) => "€" + n;
        const compute = () => {
          const menu = menus.find((m) => m.courses === state.gangen) || menus[1];
          const wijn = state.wijn === "geen" ? 0 : state.wijn === "wijn" ? menu.wine : Math.round(menu.wine * 0.6);
          return { menuPrice: menu.price, wijn, total: menu.price + wijn };
        };
        const render = () => {
          const { menuPrice, wijn, total } = compute();
          const priceEl = document.querySelector("[data-cfg-price]");
          if (priceEl) priceEl.textContent = euro(total);
          const breakEl = document.querySelector("[data-cfg-break]");
          if (breakEl) {
            let h = `<span>Menu, ${state.gangen} gangen <b>${euro(menuPrice)}</b></span>`;
            if (state.wijn === "wijn") h += `<span>Wijnarrangement <b>${euro(wijn)}</b></span>`;
            else if (state.wijn === "vrij") h += `<span>Alcoholvrij arrangement <b>${euro(wijn)}</b></span>`;
            breakEl.innerHTML = h;
          }
          const menuEl = document.querySelector("[data-cfg-menu]");
          if (menuEl) {
            const courses = savory.slice(0, state.gangen - 1).concat([dessert]);
            menuEl.innerHTML = courses
              .map((c, i) => {
                const note = state.dieet === "vega" && !c.vega ? '<span class="config__course-note">vegetarische variant</span>' : "";
                return `<div class="config__course"><span class="config__course-n">${String(i + 1).padStart(2, "0")}</span><span class="config__course-name">${c.name}${note}</span></div>`;
              })
              .join("");
          }
          document.querySelectorAll("[data-cfg]").forEach((btn) => {
            const grp = btn.getAttribute("data-cfg");
            btn.setAttribute("aria-pressed", String(state[grp]) === btn.getAttribute("data-val") ? "true" : "false");
          });
        };
        const setup = () => {
          const root = document.querySelector("[data-config]");
          if (!root) return;
          root.querySelectorAll("[data-cfg]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const grp = btn.getAttribute("data-cfg");
              let val = btn.getAttribute("data-val");
              if (grp === "gangen") val = parseInt(val, 10);
              state[grp] = val;
              render();
            });
          });
          render();
        };
        if (!window.__cfgBound) { window.__cfgBound = true; document.addEventListener("astro:page-load", setup); }
      })();
    </script>
  </section>

  <!-- 6. Galerij -->
  <section class="section-sm">
    <div class="container">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-7" data-anim="up">
        <div><p class="eyebrow">In beeld</p><h2 class="sec-title mt-4">Het pakhuis &amp; de haven</h2></div>
        <a href="/licht/ons-verhaal" class="link-line">Ons verhaal <Icon name="arrow" size={15} stroke={1.8} /></a>
      </div>
      <div class="gallery" data-anim="up">
        <a href="/licht/menukaart" class="g-a"><img src="/photos/keuken-plating.jpg" alt="Gerecht wordt opgemaakt in de keuken" loading="lazy" /></a>
        <a href="/licht/gezelschappen" class="g-b"><img src="/photos/gasten-haven.jpg" alt="Gasten aan de haven" loading="lazy" /></a>
        <a href="/licht/menukaart" class="g-c"><img src="/photos/gerecht-handen.jpg" alt="Afwerken van een gerecht" loading="lazy" /></a>
        <a href="/licht/ons-verhaal" class="g-d"><img src="/photos/haven-stad.jpg" alt="Zicht op Middelburg vanaf de haven" loading="lazy" /></a>
        <a href="/licht/ons-verhaal" class="g-e"><img src="/photos/interieur-tafels.jpg" alt="Gedekte tafels onder de balken" loading="lazy" /></a>
      </div>
    </div>
  </section>

  <!-- 7. Stats -->
  <section class="section-sm">
    <div class="container">
      <div class="stats stats--3" data-stagger>
        {homeStats.map((s) => (
          <div data-anim="up">
            <div class="stat__n">{s.n}</div>
            <div class="stat__l">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. Reviews -->
  <section class="section">
    <div class="container">
      <div class="mb-9 text-center max-w-[52ch] mx-auto" data-anim="up">
        <p class="eyebrow eyebrow--center justify-center">Gasten aan het woord</p>
        <h2 class="sec-title mt-4">Een avond om <span class="accent">bij te blijven</span></h2>
      </div>
      <div class="reviews" data-stagger>
        {reviews.map((r) => (
          <div class="review" data-anim="up">
            <div class="review__stars">{Array.from({ length: 5 }).map(() => <Icon name="star" size={15} stroke={0} class="fill-current" />)}</div>
            <p class="review__q">&ldquo;{r.q}&rdquo;</p>
            <div class="review__foot">
              <div><div class="review__name">{r.name}</div><div class="review__meta">{r.place}</div></div>
              <div class="review__src">{r.src}</div>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-[0.78rem] text-[color:var(--color-muted)] mt-7">Illustratieve gastreacties voor deze demo.</p>
    </div>
  </section>
</Base>
