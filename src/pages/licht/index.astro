---
import Base from "../../layouts/BaseLicht.astro";
import Icon from "../../components/Icon.astro";
import { site, dishes, reviews } from "../../data/site";

const signatures = dishes.filter((d) => d.sign).slice(0, 3);
const menus = [
  { courses: 4, price: 58, wine: 36 },
  { courses: 5, price: 67, wine: 45 },
  { courses: 6, price: 76, wine: 54 },
  { courses: 7, price: 83, wine: 63 },
];
const savory = dishes.slice(1, 7).map((d) => ({ name: d.name, vega: !!d.vega }));
const dessert = { name: dishes[7].name };
---

<Base loader={true}>
  <!-- ══ Hero ══════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <video autoplay muted loop playsinline poster="/photos/pand-buiten.jpg">
        <source src="/video/hero.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="hero__veil" aria-hidden="true"></div>
    <div class="hero__veil-b" aria-hidden="true"></div>
    <div class="hero__inner">
      <div class="container">
        <p class="eyebrow eyebrow--line justify-center" data-hero-fade>Aan de haven &middot; Middelburg</p>
        <h1 class="hero__name mt-6" data-hero-name>&rsquo;t Packhuys</h1>
        <p class="hero__role" data-hero-fade>
          Een <span class="w" data-role style="transition: opacity 0.3s ease, transform 0.3s ease;">belevenis</span> aan de haven.
        </p>
        <p class="hero__desc" data-hero-fade>
          Een verfijnd seizoensmenu in een eeuwenoud pakhuis, met oesters en kreeft uit ons eigen homarium.
        </p>
        <div class="hero__cta" data-hero-fade>
          <button type="button" class="btn btn-solid btn-ring" data-reserve-open>Reserveer een tafel <Icon name="arrow" size={14} stroke={1.8} /></button>
          <a href="/licht/menukaart" class="btn btn-outline">Bekijk de kaart</a>
        </div>
      </div>
    </div>
    <div class="scroll-ind" aria-hidden="true"><span>Scroll</span><div class="scroll-ind__rail"></div></div>
  </section>

  <!-- ══ Statement ═════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <p class="eyebrow eyebrow--line" data-anim="up">Het pakhuis</p>
      <h2 class="statement mt-8">
        <span data-anim="blur" class="block">Dineren waar ooit de</span>
        <span data-anim="blur" class="block"><span class="italic accent-text">handel</span> lag opgeslagen,</span>
        <span data-anim="blur" class="block">onder de balken van een</span>
        <span data-anim="blur" class="block">echt <span class="italic">pakhuis</span>.</span>
      </h2>
      <div class="grid md:grid-cols-[1fr_auto] gap-8 items-end mt-12" data-stagger>
        <p class="lede max-w-[54ch]" data-anim="up">
          Achter de dikke muren aan de Kinderdijk schuift u aan onder eeuwenoud hout, met uitzicht over de boten van de jachthaven. Onze keuken werkt met wat het seizoen en de Zeeuwse delta op dat moment te bieden hebben.
        </p>
        <a href="/licht/ons-verhaal" class="btn btn-outline" data-anim="up">Ons verhaal <Icon name="arrow" size={14} stroke={1.8} /></a>
      </div>
    </div>
  </section>

  <!-- ══ Cinematic homarium ════════════════════════════════ -->
  <section class="cinema">
    <div class="cinema__bg" aria-hidden="true"><img src="/photos/generated/homarium.jpg" alt="" data-parallax="10" /></div>
    <div class="cinema__veil" aria-hidden="true"></div>
    <div class="cinema__body">
      <div class="container">
        <img src="/brand/homarium-crest.png" alt="Homarium" class="cinema__crest" data-anim="up" />
        <p class="eyebrow eyebrow--line" data-anim="up">Onze signatuur</p>
        <h2 class="cinema__title mt-5" data-anim="up">Recht uit het <span class="italic accent-text">homarium</span></h2>
        <p class="cinema__text mt-4" data-anim="up">
          Oesters, langoustines en kreeft leven in een aquarium met gekoeld Oosterscheldewater, tot het moment dat ze op uw bord komen. De kortste route die er bestaat tussen de zee en de tafel, en u proeft het verschil.
        </p>
        <div class="flex flex-wrap gap-x-10 gap-y-4 mt-8" data-anim="up">
          <div>
            <div class="font-display text-2xl accent-text">Drie soorten</div>
            <div class="text-sm text-[color:var(--color-muted)] mt-1">Oester, langoustine en kreeft</div>
          </div>
          <div>
            <div class="font-display text-2xl">Levend gehouden</div>
            <div class="text-sm text-[color:var(--color-muted)] mt-1">In gekoeld Oosterscheldewater</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ Configurator ══════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div class="max-w-[60ch] mb-12" data-stagger>
        <p class="eyebrow eyebrow--line" data-anim="up">Stel uw avond samen</p>
        <h2 class="sec-title mt-5" data-anim="up"><span class="italic">Hoever</span> gaat u mee?</h2>
        <p class="lede mt-4" data-anim="up">Kies het aantal gangen en de begeleiding, dan ziet u meteen hoe uw avond eruitziet en wat het kost.</p>
      </div>

      <div class="config" data-config data-anim="up">
        <div class="config__form">
          <div class="config__field">
            <span class="config__qlabel">Aantal gangen</span>
            <div class="seg" role="group" aria-label="Aantal gangen">
              {menus.map((m) => (
                <button type="button" class="seg__btn" data-cfg="gangen" data-val={m.courses} aria-pressed={m.courses === 5 ? "true" : "false"}>{m.courses} gangen</button>
              ))}
            </div>
          </div>
          <div class="config__field">
            <span class="config__qlabel">Wijnbegeleiding</span>
            <div class="seg" role="group" aria-label="Wijnbegeleiding">
              <button type="button" class="seg__btn" data-cfg="wijn" data-val="geen" aria-pressed="false">Geen</button>
              <button type="button" class="seg__btn" data-cfg="wijn" data-val="wijn" aria-pressed="true">Wijnarrangement</button>
              <button type="button" class="seg__btn" data-cfg="wijn" data-val="vrij" aria-pressed="false">Alcoholvrij</button>
            </div>
          </div>
          <div class="config__field">
            <span class="config__qlabel">Voorkeur</span>
            <div class="seg" role="group" aria-label="Voorkeur">
              <button type="button" class="seg__btn" data-cfg="dieet" data-val="standaard" aria-pressed="true">Verrassen</button>
              <button type="button" class="seg__btn" data-cfg="dieet" data-val="vega" aria-pressed="false">Vegetarisch</button>
            </div>
          </div>
          <p class="text-[0.8rem] text-[color:var(--color-muted)] mt-6 leading-relaxed font-light">
            Een indicatie op basis van onze menu's. De keuken stelt de definitieve gangen samen rond het seizoen.
          </p>
        </div>
        <div class="config__panel">
          <span class="config__qlabel">Uw avond</span>
          <div class="config__price-row">
            <span class="config__price" data-cfg-price>&euro;112</span>
            <span class="config__price-sub">per persoon</span>
          </div>
          <div class="config__break" data-cfg-break></div>
          <div class="config__menu" data-cfg-menu></div>
          <button type="button" class="btn btn-solid btn-ring config__cta" data-reserve-open>Reserveer deze avond <Icon name="arrow" size={14} stroke={1.8} /></button>
        </div>
      </div>
    </div>

    <script is:inline define:vars={{ menus, savory, dessert }}>
      (function () {
        const state = { gangen: 5, wijn: "wijn", dieet: "standaard" };
        const euro = (n) => "€" + n;
        const compute = () => {
          const menu = menus.find((m) => m.courses === state.gangen) || menus[1];
          const wijn = state.wijn === "geen" ? 0 : state.wijn === "wijn" ? menu.wine : Math.round(menu.wine * 0.6);
          return { menuPrice: menu.price, wijn, total: menu.price + wijn };
        };
        const render = () => {
          const { menuPrice, wijn, total } = compute();
          const priceEl = document.querySelector("[data-cfg-price]");
          if (priceEl) priceEl.textContent = euro(total);
          const breakEl = document.querySelector("[data-cfg-break]");
          if (breakEl) {
            let h = `<span>Menu, ${state.gangen} gangen <b>${euro(menuPrice)}</b></span>`;
            if (state.wijn === "wijn") h += `<span>Wijnarrangement <b>${euro(wijn)}</b></span>`;
            else if (state.wijn === "vrij") h += `<span>Alcoholvrij arrangement <b>${euro(wijn)}</b></span>`;
            breakEl.innerHTML = h;
          }
          const menuEl = document.querySelector("[data-cfg-menu]");
          if (menuEl) {
            const courses = savory.slice(0, state.gangen - 1).concat([dessert]);
            menuEl.innerHTML = courses
              .map((c, i) => {
                const note = state.dieet === "vega" && !c.vega ? '<span class="config__course-note">vegetarische variant</span>' : "";
                return `<div class="config__course"><span class="config__course-n">${String(i + 1).padStart(2, "0")}</span><span class="config__course-name">${c.name}${note}</span></div>`;
              })
              .join("");
          }
          document.querySelectorAll("[data-cfg]").forEach((btn) => {
            const grp = btn.getAttribute("data-cfg");
            btn.setAttribute("aria-pressed", String(state[grp]) === btn.getAttribute("data-val") ? "true" : "false");
          });
        };
        const setup = () => {
          const root = document.querySelector("[data-config]");
          if (!root) return;
          root.querySelectorAll("[data-cfg]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const grp = btn.getAttribute("data-cfg");
              let val = btn.getAttribute("data-val");
              if (grp === "gangen") val = parseInt(val, 10);
              state[grp] = val;
              render();
            });
          });
          render();
        };
        if (!window.__cfgBound) { window.__cfgBound = true; document.addEventListener("astro:page-load", setup); }
      })();
    </script>
  </section>

  <!-- ══ Parallax gallery ══════════════════════════════════ -->
  <section class="section overflow-hidden">
    <div class="container text-center mb-4">
      <p class="eyebrow eyebrow--line justify-center" data-anim="up">In beeld</p>
      <h2 class="sec-title mt-5" data-anim="up">Het pakhuis &amp; de <span class="italic">haven</span></h2>
    </div>
    <div class="gallery-cols container-wide">
      <div class="gallery-col" data-parallax="-7">
        <div class="gallery-item"><img src="/photos/keuken-plating.jpg" alt="Gerecht wordt opgemaakt in de keuken" loading="lazy" /></div>
        <div class="gallery-item"><img src="/photos/wijn-tafel.jpg" alt="Wijn wordt ingeschonken aan tafel" loading="lazy" /></div>
        <div class="gallery-item"><img src="/photos/gasten-haven.jpg" alt="Gasten aan de haven" loading="lazy" /></div>
      </div>
      <div class="gallery-col gallery-col--b" data-parallax="7">
        <div class="gallery-item"><img src="/photos/gerecht-handen.jpg" alt="Afwerken van een gerecht" loading="lazy" /></div>
        <div class="gallery-item"><img src="/photos/haven-stad.jpg" alt="Zicht op Middelburg vanaf de haven" loading="lazy" /></div>
        <div class="gallery-item"><img src="/photos/interieur-tafels.jpg" alt="Gedekte tafels onder de balken" loading="lazy" /></div>
      </div>
    </div>
  </section>

  <!-- ══ Stats ═════════════════════════════════════════════ -->
  <section class="section-sm">
    <div class="container">
      <div class="stats" data-stagger>
        <div data-anim="up"><div class="stat__n"><span class="italic accent-text">V.O.C.</span></div><div class="stat__l">Een pakhuis uit de Zeeuwse handelstijd</div></div>
        <div data-anim="up"><div class="stat__n">4-7</div><div class="stat__l">Gangen, samengesteld rond het seizoen</div></div>
        <div data-anim="up"><div class="stat__n">100%</div><div class="stat__l">Huisgemaakt, niets uit blik</div></div>
      </div>
    </div>
  </section>

  <!-- ══ Reviews ═══════════════════════════════════════════ -->
  <section class="section-sm">
    <div class="container">
      <div class="mb-9" data-anim="up">
        <p class="eyebrow eyebrow--line">Gasten aan het woord</p>
        <h2 class="sec-title mt-5">Een avond om <span class="italic">bij te blijven</span></h2>
      </div>
      <div class="reviews" data-stagger>
        {reviews.map((r) => (
          <div class="review" data-anim="up">
            <div class="review__stars">{Array.from({ length: 5 }).map(() => <Icon name="star" size={15} stroke={0} class="fill-current" />)}</div>
            <p class="review__q">&ldquo;{r.q}&rdquo;</p>
            <div class="review__foot">
              <div><div class="review__name">{r.name}</div><div class="text-[0.74rem] text-[color:var(--color-muted)]">{r.place}</div></div>
              <div class="review__src">{r.src}</div>
            </div>
          </div>
        ))}
      </div>
      <p class="text-[0.78rem] text-[color:var(--color-muted)] mt-7">Illustratieve gastreacties voor deze demo.</p>
    </div>
  </section>

  <script is:inline>
    (function () {
      const roles = ["belevenis", "ontdekking", "klassieker", "avond"];
      function startRoles() {
        const el = document.querySelector("[data-role]");
        if (!el || window.__rolesBound) return;
        window.__rolesBound = true;
        let i = 0;
        setInterval(() => {
          i = (i + 1) % roles.length;
          el.style.opacity = "0";
          el.style.transform = "translateY(6px)";
          setTimeout(() => { el.textContent = roles[i]; el.style.opacity = "1"; el.style.transform = "none"; }, 220);
        }, 2400);
      }
      document.addEventListener("astro:page-load", startRoles);
    })();
  </script>
</Base>
