---
import Icon from "./Icon.astro";
// Lichte multipage: zelfde paginastructuur als de donkere demo, /licht/-prefix.
const links = [
  { href: "/licht/menukaart", label: "Menukaart" },
  { href: "/licht/wijnen", label: "Wijnen" },
  { href: "/licht/ons-verhaal", label: "Ons verhaal" },
  { href: "/licht/gezelschappen", label: "Gezelschappen" },
  { href: "/licht/contact", label: "Contact" },
];
const sheetLinks = [{ href: "/licht", label: "Home" }, ...links];
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isCurrent = (href: string) => path === href.replace(/\/+$/, "");
---

<nav class="nav" data-nav aria-label="Hoofdmenu">
  <div class="nav__pill">
    <a href="/licht" class="nav__logo" aria-label="Het Packhuys, naar home">
      <img src="/brand/homarium-crest.png" alt="" class="nav__crest" aria-hidden="true" />
      <span class="nav__wordmark">Het <b>Packhuys</b></span>
    </a>
    <span class="nav__divider"></span>
    <div class="nav__links inline-flex items-center">
      {links.map((l) => <a href={l.href} class="nav__link" aria-current={isCurrent(l.href) ? "page" : undefined}>{l.label}</a>)}
    </div>
    <span class="nav__divider"></span>
    <button type="button" class="nav__cta" data-reserve-open>
      Reserveren
      <Icon name="arrowUpRight" size={13} stroke={1.8} />
    </button>
    <button type="button" class="nav__toggle" data-nav-toggle aria-label="Open menu" aria-expanded="false">
      <Icon name="menu" size={20} stroke={1.8} />
    </button>
  </div>
</nav>

<aside class="navsheet" data-navsheet aria-label="Mobiel menu">
  <button type="button" class="absolute top-6 right-6 nav__toggle" data-nav-toggle aria-label="Sluit menu">
    <Icon name="close" size={22} stroke={1.8} />
  </button>
  {sheetLinks.map((l, i) => (
    <a href={l.href} aria-current={isCurrent(l.href) ? "page" : undefined}>{l.label}<span>{String(i).padStart(2, "0")}</span></a>
  ))}
  <button type="button" class="btn btn-solid mt-10 self-start" data-reserve-open>
    Reserveren <Icon name="arrowUpRight" size={14} stroke={1.8} />
  </button>
</aside>
