---
import { site } from "../data/site";
import Icon from "./Icon.astro";
const shots = ["gerecht-zeebaars", "interieur-avond", "wijn-inschenken", "keuken-plating", "haven-masten", "gasten-proost"];
---
<section class="section-sm">
  <div class="container">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-7" data-anim="up">
      <div>
        <p class="eyebrow eyebrow--line">Instagram</p>
        <h2 class="sec-title mt-5">@restauranthetpackhuys</h2>
      </div>
      <a href={site.social.instagram} target="_blank" rel="noopener" class="btn btn-outline"><Icon name="instagram" size={16} /> Volgen</a>
    </div>
    <div class="ig" data-anim="up">
      {shots.map((s) => (
        <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Bekijk op Instagram">
          <img src={`/photos/${s}.jpg`} alt="" loading="lazy" />
        </a>
      ))}
    </div>
    <p class="text-[0.8rem] text-[color:var(--color-muted)] mt-5 text-center">Live gekoppeld, toont automatisch de nieuwste posts.</p>
  </div>
</section>
